{
  "manifest_version": 3,
  "name": "Notion Emoji Injector",
  "version": "5.1",
  "description": "Replaces Notion emojis with styled color emojis.",
  "permissions": ["storage"],
  "host_permissions": ["*://app.notion.com/*"],
  "icons": {
    "16": "Icon.png",
    "48": "Icon.png",
    "128": "Icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://app.notion.com/*"],
      "js": ["emojiReplacer.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "Icon.png"
  },
  "homepage_url": "https://github.com/Sadlyfizzx/Apple-Color-Emojis-Injector",
  "author": "Ziad"
}